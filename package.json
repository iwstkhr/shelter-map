    "react-icons": "5.7.0",
    "react-router": "8.2.0"
  },
  "devDependencies": {
    "@biomejs/biome": "2.5.4",
    "@react-router/dev": "8.2.0",
    "@secretlint/secretlint-rule-preset-recommend": "13.0.2",
